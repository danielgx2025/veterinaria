# Base de datos
DB_USERNAME=postgres
DB_PASSWORD=cambiar_en_produccion
# En dev el DB_DATABASE es siempre "veterinaria" (definido en docker-compose)

# JWT
JWT_SECRET=generar_con_openssl_rand_hex_32
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# App
FRONTEND_URL=https://tu-dominio.com   # en dev: http://localhost:5173
APP_PORT=80                           # puerto expuesto en producción
